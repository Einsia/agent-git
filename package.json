{
  "name": "@einsia/agentgit",
  "version": "0.1.0",
  "description": "Git for agent context: version raw agent session dumps, sync with your team, LLM-merge on pull. Installs the prebuilt agit client binary. The agit-hub server is distributed separately (Docker / build from source).",
  "keywords": [
    "agit",
    "agent",
    "git",
    "llm",
    "claude",
    "claude-code",
    "session",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Einsia/agent-git#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Einsia/agent-git.git"
  },
  "bugs": {
    "url": "https://github.com/Einsia/agent-git/issues"
  },
  "bin": {
    "agit": "npm/shim.js"
  },
  "files": [
    "npm/shim.js",
    "npm/install.js",
    "npm/lib/",
    "npm/README.md",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node npm/install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
